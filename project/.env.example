# CC Invest - Crypto Trading System
# 项目配置文件

# 数据库配置
DATABASE_URL=postgresql://user:password@localhost:5432/ccinvest
# DATABASE_URL=sqlite:///data/ccinvest.db  # 如果使用 SQLite

# 交易所 API (示例：Binance)
BINANCE_API_KEY=your_api_key_here
BINANCE_API_SECRET=your_api_secret_here

# 模拟/实盘模式
# paper = 模拟交易
# live = 实盘交易
TRADING_MODE=paper

# 风控参数
MAX_POSITION_SIZE=0.02        # 单笔最大仓位 2%
MAX_TOTAL_POSITION=0.10       # 总持仓上限 10%
MAX_DAILY_LOSS=1000.0         # 单日最大亏损 USDT
MAX_DRAWDOWN=0.05            # 最大回撤 5%
STOP_LOSS_PERCENT=0.02       # 止损线 2%

# 数据采集间隔 (秒)
DATA_COLLECTION_INTERVAL=300  # 5分钟

# OpenClaw 配置
OPENCLAW_HOST=http://localhost:10000
OPENCLAW_WEBHOOK_TOKEN=your_webhook_secret_here

# 日志配置
LOG_LEVEL=INFO
LOG_FILE=logs/ccinvest.log

# 回测配置
BACKTEST_START_DATE=2023-01-01
BACKTEST_END_DATE=2024-01-01
INITIAL_CAPITAL=10000.0       # 初始资金 USDT

# 策略参数
MEAN_THRESHOLD=2             # 均值回归阈值 (标准差倍数)
RSI_OVERSOLD=30              # RSI 超卖线
RSI_OVERBOUGHT=70             # RSI 超买线
MA_SHORT=20                  # 短期均线
MA_LONG=50                   # 长期均线

# 通知配置 (可选)
SLACK_WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=